FROM dromni/nerfstudio:1.1.4

# Execution infrastructure (papermill + W&B + HF Hub)
RUN pip install --no-cache-dir \
    papermill nbformat nbclient wandb huggingface_hub ipykernel pyyaml tqdm

# Image already has user "user" (UID 1000) with sudo — use that
USER user

# Register ipykernel (as user, not root — avoids permission issues)
RUN python3 -m ipykernel install --user --name python3 --display-name "Python 3 (nerfstudio)"
RUN git config --global commit.gpgsign false
