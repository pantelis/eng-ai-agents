FROM pytorch/pytorch:2.7.1-cuda12.8-cudnn9-devel

# gsplat distributes a py3-none-any wheel that JIT-compiles CUDA kernels
# at first import, so nvcc (from the -devel image) is required.

ARG USERNAME=vscode
ARG USER_UID=1001
ARG USER_GID=$USER_UID

# Create non-root user (matches host UID on gpu-node-3)
RUN groupadd --gid $USER_GID $USERNAME \
  && useradd -s /bin/bash --uid $USER_UID --gid $USER_GID -m $USERNAME \
  && apt-get update \
  && apt-get install -y sudo \
  && echo $USERNAME ALL=\(root\) NOPASSWD:ALL > /etc/sudoers.d/$USERNAME \
  && chmod 0440 /etc/sudoers.d/$USERNAME \
  && rm -rf /var/lib/apt/lists/*

# System packages
RUN apt-get update && export DEBIAN_FRONTEND=noninteractive \
  && apt-get -y install --no-install-recommends \
       curl git git-lfs ffmpeg make bash-completion openssh-client \
  && rm -rf /var/cache/apt && apt-get clean

# Freeze pre-installed package versions as constraints
RUN mkdir -p /etc/pip \
  && pip list --format=freeze > /etc/pip/constraint.txt

# gsplat core
RUN pip install --no-cache-dir gsplat==1.5.3

# gsplat example dependencies (simple_trainer.py)
# Step 1: PyPI packages
RUN pip install --no-cache-dir \
    "numpy<2.0.0" scipy scikit-learn opencv-python Pillow piexif \
    "imageio[ffmpeg]" tensorboard "torchmetrics[image]" tensorly \
    "tyro>=0.8.8" pyyaml tqdm matplotlib splines \
    viser \
    git+https://github.com/rmbrualla/pycolmap@cc7ea4b7301720ac29287dbe450952511b32125e \
    git+https://github.com/nerfstudio-project/nerfview@4538024fe0d15fd1a0e4d760f3695fc44ca72787

# Step 2: CUDA extensions that import torch at build time (need --no-build-isolation)
RUN pip install --no-cache-dir --no-build-isolation \
    git+https://github.com/rahul-goel/fused-ssim@328dc9836f513d00c4b5bc38fe30478b4435cbb5 \
    git+https://github.com/harry7557558/fused-bilagrid@49f0ef06c9f81810fb9b5dd9027cf1844950cc16 \
    git+https://github.com/nv-tlabs/ppisp@v1.0.0

# Execution infrastructure (papermill + W&B + HF Hub)
RUN pip install --no-cache-dir \
    papermill nbformat nbclient wandb huggingface_hub ipykernel pyyaml

USER $USERNAME

RUN python3 -m ipykernel install --user --name python3 --display-name "Python 3 (gsplat)"
RUN git config --global commit.gpgsign false
